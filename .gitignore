# ============================================
# PYTHON
# ============================================

# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Python cache
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/
.tox/
.nox/

# Coverage reports
.coverage
.coverage.*
htmlcov/

# Logs
*.log

# ============================================
# DJANGO
# ============================================

# SQLite database
db.sqlite3
*.sqlite3

# Uploaded media (optional - remove if you want media in Git)
media/

# Collected static files
staticfiles/

# Local settings
local_settings.py

# ============================================
# VIRTUAL ENVIRONMENTS
# ============================================

venv/
.venv/
env/
ENV/

# ============================================
# ENVIRONMENT VARIABLES
# ============================================

.env
.env.*
!.env.example

# ============================================
# NODE / REACT
# ============================================

frontend/node_modules/
frontend/build/
frontend/dist/

# npm / yarn / pnpm logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ============================================
# IDEs
# ============================================

.vscode/
.idea/

# ============================================
# OPERATING SYSTEM FILES
# ============================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Desktop.ini

# ============================================
# GIT
# ============================================

*.orig

# ============================================
# MISC
# ============================================

*.swp
*.swo
*~

